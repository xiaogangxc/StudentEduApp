<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_main">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:padding="16dp">

        <Button
            android:id="@+id/btnHomework"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="16dp"
            android:text="@string/btn_homework"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_homework" />

        <Button
            android:id="@+id/btnPosture"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="16dp"
            android:text="@string/btn_posture"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_posture" />

        <Button
            android:id="@+id/btnArchive"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="16dp"
            android:text="@string/btn_archive"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_archive" />

        <Button
            android:id="@+id/btnUsb"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="16dp"
            android:text="@string/btn_usb"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_usb" />

        <Button
            android:id="@+id/btnReportPush"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="16dp"
            android:text="@string/btn_report_push"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_report_push" />

    </GridLayout>

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/btn_settings"
        android:textSize="18sp"
        android:backgroundTint="@color/btn_settings" />

</LinearLayout>