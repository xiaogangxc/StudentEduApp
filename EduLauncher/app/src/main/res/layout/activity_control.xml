<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_control">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_control"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="64dp" />

    <Button
        android:id="@+id/btnStartSystem"
        style="@style/ControlButtonStyle"
        android:text="@string/btn_start"
        android:backgroundTint="@color/status_running"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnStopSystem"
        style="@style/ControlButtonStyle"
        android:text="@string/btn_stop"
        android:backgroundTint="@color/status_stopped" />

</LinearLayout>